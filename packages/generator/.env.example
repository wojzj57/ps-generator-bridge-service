# Generator runtime
# Defaults to 7700 when unset or invalid.
PS_BRIDGE_PORT=7700

# Defaults to packages/generator/plugins when unset.
PS_BRIDGE_PLUGINS_DIR=

# Optional platform-delimited absolute plugin package paths loaded before PLUGINS_DIR.
# Windows example: D:\plugins\paint;E:\team-tools\exporter
PS_BRIDGE_PLUGINS=

# Defaults to packages/generator/logs from main.js when unset.
PS_BRIDGE_LOG_DIR=


# COS
# Tencent COS upload configuration.
# Leave these blank to disable COS-backed image/document export URLs.
PS_BRIDGE_COS_SECRET_ID=
PS_BRIDGE_COS_SECRET_KEY=
PS_BRIDGE_COS_BUCKET=
PS_BRIDGE_COS_REGION=

# Optional COS upload tuning.
# Defaults to ps-bridge/exports.
PS_BRIDGE_COS_KEY_PREFIX=ps-bridge/exports

# Defaults to 315,360,000 seconds (10 years).
PS_BRIDGE_COS_URL_EXPIRES=315360000
